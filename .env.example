APP_ENV=local
LOG_LEVEL=INFO

# Telegram
TELEGRAM_BOT_TOKEN=123456:replace-me
BOT_MODE=polling
WEBHOOK_BASE_URL=https://your-domain.com
WEBHOOK_SECRET=replace-with-random-secret

# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_ENABLED=false
OPENAI_MODEL=gpt-4o
OPENAI_MAX_OUTPUT_TOKENS=1800
OPENAI_TIMEOUT_SECONDS=35
RULE_BASED_FALLBACK_ENABLED=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/sales_qa.sqlite3

# OCR
OCR_LANGUAGE=rus+eng
TESSERACT_CMD=

# Runtime limits
MAX_IMAGES_PER_SESSION=10
MAX_IMAGE_MB=15
SESSION_TTL_MINUTES=30
ALBUM_DEBOUNCE_SECONDS=4
RATE_LIMIT_PER_MINUTE=6
DELETE_IMAGES_AFTER_ANALYSIS=true

# Admins: comma-separated Telegram user IDs allowed to run /stats.
ADMIN_USER_IDS=
